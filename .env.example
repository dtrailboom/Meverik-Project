# App
NODE_ENV=development
PORT=3000
APP_URL=http://localhost:3000

# MongoDB
MONGO_URI=mongodb://localhost:27017/meverik

# Session
SESSION_SECRET=replace_with_a_long_random_string_at_least_64_chars

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe Price IDs (create these in your Stripe dashboard)
STRIPE_PRICE_STARTER=price_...
STRIPE_PRICE_GROWTH=price_...
STRIPE_PRICE_PRO=price_...

# Stripe One-time Top-up Price IDs
STRIPE_PRICE_TOPUP_SMALL=price_...
STRIPE_PRICE_TOPUP_MEDIUM=price_...
STRIPE_PRICE_TOPUP_LARGE=price_...

# Email (SMTP)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=hello@meverik.com
SMTP_PASS=your_smtp_password
EMAIL_FROM=Meverik <hello@meverik.com>

# Admin
ADMIN_EMAIL=admin@meverik.com
